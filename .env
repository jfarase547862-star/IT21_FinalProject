# PostgreSQL database configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=it21_db
DB_USER=postgres
DB_PASSWORD=123456

# Spring Boot runtime port (optional)
PORT=8081

# Gmail SMTP for forgot-password emails (use a Google App Password, not your normal password)
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-16-char-app-password
MAIL_FROM=your-email@gmail.com

# Public URL for reset links (required on Render, e.g. https://your-app.onrender.com)
APP_BASE_URL=http://localhost:8081
